# server-deploy-conflict.env —— 多环境配置冲突样例
# 问题：本地/测试/线上混在一个文件里，接口地址与端口冲突，模型服务地址写死本机

NODE_ENV=production
# 本地开发地址（不应出现在生产配置里）
VITE_API_BASE=http://localhost:8080
# 又写了一个线上地址，重复冲突
VITE_API_BASE=http://192.168.0.103:8080
# 模型服务地址写死本机 127.0.0.1，服务器上不可用
VITE_OLLAMA_URL=http://127.0.0.1:11434
VITE_COMFYUI_URL=http://127.0.0.1:8188
# 端口与后端 8080 冲突
PORT=8080
DEV_SERVER_PORT=8080
# 调试开关在生产仍为 true
VITE_DEBUG=true
# 缺少 VITE_ENV 区分环境
# 缺少线上 HTTPS / 域名配置
