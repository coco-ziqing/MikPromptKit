# PromptKit .gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Database
data/prompts.db
data/packages/*.pkb

# Media assets
data/originals/
data/thumbnails/
data/videos/

# Backups
data/backups/

# Test scripts
backend/test_*.py
backend/check_*.py
backend/peek.py
backend/*.bak

# OS
.DS_Store
Thumbs.db

# Build output
dist/
build/
*.spec.bak
# macOS build
dist_macos/
*.dmg
macos/resources/app.icns
macos/resources/app_icon.iconset/


# Build artifacts
*.db


# Data (user-generated)
!data/.gitkeep

prompts.db-*

# Database backups
*.before_view_migration
*.unify_final_bak
*_before_unify.bak

# Word card user media
frontend/static/js/media-cache/
data/wc_media/originals/
data/wc_media/thumbs/
data/wc_media/videos/
data/wordcard_thumbs/
data/wordcard_videos/

# Temporary scripts
_shutdown.py
_v5.py
_verify2.py

# Dream/memory session files
memory/.dreams/
