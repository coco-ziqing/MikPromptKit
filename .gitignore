# .gitignore — PromptKit v3.0.0.2
# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.spec

# Data (tracked separately)
data/thumbnails/*
!data/thumbnails/.gitkeep
data/videos/*
!data/videos/.gitkeep
data/originals/*
!data/originals/.gitkeep
*.db-shm
*.db-wal

# IDE
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store

# Temp
_version_check.py
_release.ps1
_temp.txt
_replacement.py
_hb.ps1
